{
  "compilerOptions": {
    "outDir": "./dist",
    "rewriteRelativeImportExtensions": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "checkJs": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "module": "es2022",
    "moduleResolution": "node",
    "target": "es2022"
  }
}
